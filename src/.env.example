DATABASE_HOST=<mysql_host>
DATABASE_PORT=3306
DATABASE_NAME=<dbname>
DATABASE_USERNAME=<db_user>
DATABASE_PASSWORD=<db_pw>
# Optional: set to "false" to disable SSL, or to allow self-signed certs
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_CA_CERT=<pem_contents>
APPLICATIONINSIGHTS_CONNECTION_STRING=<app_insights>

# Recipes (Tandoor) API
TANDOOR_TOKEN=<tandoor_api_token>

# Public URLs (overridable; sensible production defaults exist in code)
# NEXT_PUBLIC_RESUME_URI=https://.../resume.pdf
# NEXT_PUBLIC_TANDOOR_URI=https://cook.sanskagarwal.com
# NEXT_PUBLIC_REMARK_URI=https://commento.sanskagarwal.com
