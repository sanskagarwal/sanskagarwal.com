    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/instrumentation": "^0.218.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0"
  },
  "main": "dist/src/{index.js,functions/*.js}"
}
