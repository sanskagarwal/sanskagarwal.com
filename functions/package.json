{
  "name": "functions",
  "version": "2.0.0",
  "description": "Heartbeat health checks for sanskagarwal.com endpoints with OpenTelemetry.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "test": "echo \"No tests yet...\""
  },
  "dependencies": {
    "@azure/functions": "^4.16.0",
    "@azure/functions-opentelemetry-instrumentation": "^0.3.0",
